NODE_ENV=production
PORT=4000

# Hostinger MySQL
DATABASE_URL=mysql://u209468809_USERNAME:PASSWORD@HOST:3306/u209468809_fieldserviceit

# Public URLs
FRONTEND_URL=https://fieldserviceit.com
API_URL=https://api.fieldserviceit.com
CORS_ORIGIN=https://fieldserviceit.com

# Security
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-separate-long-random-secret
BACKUP_DIR=./backups
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_REQUIRED=false
OIDC_ALLOW_PRIVATE_ISSUERS=false

# PayPal subscriptions (only supported billing provider)
BILLING_PROVIDER=PAYPAL
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=production
PAYPAL_SUBSCRIPTION_MANAGE_URL=https://www.paypal.com/myaccount/autopay/

# Hostinger email delivery (implicit SSL)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@fieldserviceit.com
SMTP_PASS=
SMTP_FROM=support@fieldserviceit.com
SMTP_REPLY_TO=support@fieldserviceit.com

# Email provider webhooks
INBOUND_EMAIL_API_KEY=
EMAIL_WEBHOOK_API_KEY=

# Optional Sentry error and performance monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
# Optional model-assisted AI Agent configuration.
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-5.4-mini
AI_REASONING_EFFORT=low
AI_TIMEOUT_MS=20000

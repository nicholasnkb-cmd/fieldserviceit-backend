DATABASE_URL="mysql://app:devpassword@localhost:3306/fieldserviceit"
JWT_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
JWT_EXPIRES_IN="15m"
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# SMTP (MailHog on localhost:1025 by default)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@fieldserviceit.com"
SMTP_REPLY_TO=""

# Frontend URL (for password reset links)
FRONTEND_URL="http://localhost:3000"

# PayPal is the only billing provider
BILLING_PROVIDER="PAYPAL"
BILLING_GRACE_PERIOD_DAYS="7"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENVIRONMENT="sandbox"
PAYPAL_SUBSCRIPTION_MANAGE_URL="https://www.paypal.com/myaccount/autopay/"

# Storage type: "local" (default) or "s3"
STORAGE_TYPE="local"

# S3-compatible storage (only used when STORAGE_TYPE=s3)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="fieldserviceit-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Set to "true" to enable Swagger docs in production
SWAGGER_ENABLED="false"

# API key for inbound email webhook (optional, leave empty to disable check)
INBOUND_EMAIL_API_KEY=""
EMAIL_WEBHOOK_API_KEY=""
# Optional AI reasoning provider. Without these values, the AI Agent uses its deterministic fallback.
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-5.4-mini
AI_REASONING_EFFORT=low
AI_TIMEOUT_MS=20000
